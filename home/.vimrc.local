" GPG Settings
let g:GPGPreferArmor = 1
let g:GPGUseAgent    = 1
let g:GPGExecutable  = '/usr/local/bin/gpg'

set clipboard=unnamed

set noignorecase
set hidden

" solarized theme
syntax enable
let g:solarized_termtrans = 1
set background=light
colorscheme solarized

set showbreak=...
set wrap linebreak nolist

" disable arrow keys
map <up> <nop>
map <down> <nop>
map <left> <nop>
map <right> <nop>
imap <up> <nop>
imap <down> <nop>
imap <left> <nop>
imap <right> <nop>
